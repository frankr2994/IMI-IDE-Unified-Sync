{
  "name": "imi-ide-merge-integrations",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on -t 30000 http://127.0.0.1:3333 && cross-env NODE_ENV=development ELECTRON_BUILDER_OFFLINE=true NO_UPDATE_NOTIFIER=1 npm_config_update_notifier=false ADBLOCK=true electron .\"",
    "electron:build": "npm run build && electron-builder",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.imi.ide.integrations",
    "productName": "IMI IDE MERGE INTEGRATIONS",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ]
  },
  "dependencies": {
    "framer-motion": "^11.3.28",
    "lucide-react": "^0.428.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "wait-on": "^7.2.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0"
  }
}